# PEXCRAFT Windows cross-build Makefile.
# GNU make has built-in CC=cc, so use WIN_CC instead of CC.

WIN_CC ?= i686-w64-mingw32-gcc
CFLAGS ?= -std=c99 -O2 -Wall -Wextra
LDFLAGS ?= -mwindows
LIBS = -ld3d11 -ldxgi -ld3dcompiler -ld3d9 -lopengl32 -lglu32 -lgdi32 -luser32 -lshell32 -lole32 -loleaut32 -lwindowscodecs -lcomdlg32 -lwinmm -lws2_32 -lz -lm

TARGET = pexcraft.exe

.PHONY: all clean run

all: $(TARGET)

$(TARGET): main.c $(wildcard src/*/*.c) src/common/common.h
	$(WIN_CC) $(CFLAGS) main.c -o $@ $(LDFLAGS) $(LIBS)

run: $(TARGET)
	./$(TARGET)

clean:
	rm -f $(TARGET)


.PHONY: remote
remote: pexcraft_remote.exe

pexcraft_remote.exe: main.c $(wildcard src/*/*.c) src/common/common.h
	$(WIN_CC) $(CFLAGS) -DPEX_REMOTE_HTTP=1 -DPEX_REMOTE_FPS=30 main.c -o $@ $(LDFLAGS) $(LIBS)
